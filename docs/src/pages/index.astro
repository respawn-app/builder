---
import { resolveDocsConfig } from '../../scripts/site-config.mjs';

const docsConfig = resolveDocsConfig();
const docsTargetPath = `${docsConfig.basePath}${docsConfig.docsHomePath}` || docsConfig.docsHomePath;
const docsTargetUrl = docsConfig.getPublicUrl(docsConfig.docsHomePath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${docsTargetPath}`} />
    <link rel="canonical" href={docsTargetUrl} />
    <title>Redirecting | Builder</title>
  </head>
  <body>
    <script is:inline set:html={`window.location.replace(${JSON.stringify(docsTargetPath)});`} />
    <p>
      Redirecting to <a href={docsTargetPath}>{docsTargetUrl}</a>.
    </p>
  </body>
</html>
